  "use": "ca.concordia.encs.citydata.producers.CalibrationProducer",
  "withParams": [
    { "name": "filePath", "value": "src/main/resources/Data/OMHM_electricity.csv" }
  ],
  "apply": [
    {
      "name": "ca.concordia.encs.citydata.operations.CSVFilterOperation",
      "withParams": [
