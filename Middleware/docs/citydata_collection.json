		{
			"name": "2. Auth",
			"item": [
				{
					"name": "authenticate",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.collectionVariables.set(\"token\", pm.response.text().trim());"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
					],
					"request": {
						"auth": {
							"type": "basic",
							"basic": [
								{
									"key": "password",
									"value": "citydata",
									"type": "string"
								},
								{
									"key": "username",
									"value": "citydata",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseURL}}/authenticate",
							"host": [
								"{{baseURL}}"
							],
							"path": [
								"authenticate"
							]
						}
					},
					"response": []
				}
			],
			"description": "Make a request to /authenticate to log in with a username and password (go to the Authorization tab, select Basic Auth and then type your credentials). Please make sure that your credentials exist in the CITYdata instance you want to connect before you use them. For more information on authentication, please check our README."
		},
		{
			"name": "3. Apply",
			"item": [
				{
					"name": "apply/sync",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"use\": \"ca.concordia.encs.citydata.producers.RandomNumberProducer\",\n  \"withParams\": [\n    {\n      \"name\": \"listSize\",\n      \"value\": 5\n    }\n  ],\n  \"apply\": [\n    {\n      \"name\": \"ca.concordia.encs.citydata.operations.AverageOperation\",\n      \"withParams\": [\n        {\n          \"name\": \"roundingMethod\",\n          \"value\": \"floor\"\n        }\n      ]\n    },\n    {\n      \"name\": \"ca.concordia.encs.citydata.operations.MergeOperation\",\n      \"withParams\": [\n        {\n          \"name\": \"targetProducer\",\n          \"value\": \"ca.concordia.encs.citydata.producers.RandomNumberProducer\"\n        },\n        {\n          \"name\": \"targetProducerParams\",\n          \"value\": [\n            {\n              \"name\": \"listSize\",\n              \"value\": 5\n            }\n          ]\n        }\n      ]\n    }\n  ]\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseURL}}/apply/sync",
							"host": [
								"{{baseURL}}"
							],
							"path": [
								"apply",
								"sync"
							]
						}
					},
					"response": []
				},
